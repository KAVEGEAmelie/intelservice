# Envoi des emails du formulaire de contact via Resend (https://resend.com).
# En local ou en preview, vous pouvez laisser cette clé vide :
# le formulaire restera fonctionnel et les messages seront simplement journalisés.
RESEND_API_KEY=
# Adresse email qui recevra les demandes envoyées depuis le site.
# En production, utilisez de préférence une adresse métier de l'entreprise.
CONTACT_TO_EMAIL=infos_its@yahoo.fr
